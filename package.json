{
  "name": "begyn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "mobile:build": "pnpm build && pnpm exec cap sync",
    "cap:sync": "pnpm exec cap sync",
    "cap:copy": "pnpm exec cap copy",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:open:android": "pnpm exec cap open android",
    "cap:run:ios": "pnpm build && pnpm exec cap run ios",
    "cap:run:android": "pnpm build && pnpm exec cap run android",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
